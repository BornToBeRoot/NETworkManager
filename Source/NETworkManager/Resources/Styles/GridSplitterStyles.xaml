<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <!--
    Drag-preview adorner shown while a GridSplitter with ShowsPreview="True" is being dragged.
    Without an explicit PreviewStyle, WPF falls back to its own built-in default (an opaque
    black/dark-gray rectangle) which doesn't react to the app's light/dark theme.
    -->
    <Style x:Key="GridSplitterPreviewStyle" TargetType="{x:Type Control}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Fill="{DynamicResource MahApps.Brushes.Gray8}" Opacity="0.5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VerticalGridSplitter" TargetType="{x:Type GridSplitter}">
        <Setter Property="Width" Value="7" />
        <Setter Property="Margin" Value="-3,-3" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Panel.ZIndex" Value="1" />
        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}" />
        <Setter Property="ShowsPreview" Value="True" />
        <Setter Property="PreviewStyle" Value="{StaticResource GridSplitterPreviewStyle}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Grid>
                        <!-- Border alone carries Background/BorderBrush (hit area, divider fill).
                             The icon is a sibling, not its child, so Border's content-box inset
                             (BorderThickness eating into the splitter's own 7px Width) doesn't
                             clip it - it can render at a legible size regardless of how thin the
                             splitter itself is. -->
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <iconPacks:PackIconMaterial Kind="DragVerticalVariant"
                                                     Width="16" Height="16"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     IsHitTestVisible="False">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="{x:Type iconPacks:PackIconMaterial}">
                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}" />
                                    <Setter Property="Visibility" Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type GridSplitter}}, Path=IsMouseOver}" Value="True">
                                            <!--<Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray5}" />-->
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="HorizontalGridSplitter" TargetType="{x:Type GridSplitter}">
        <Setter Property="Height" Value="7" />
        <Setter Property="Margin" Value="-3,-3" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Panel.ZIndex" Value="1" />
        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}" />
        <Setter Property="ShowsPreview" Value="True" />
        <Setter Property="PreviewStyle" Value="{StaticResource GridSplitterPreviewStyle}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ResizeDirection" Value="Rows" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Grid>
                        <!-- Border alone carries Background/BorderBrush (hit area, divider fill).
                             The icon is a sibling, not its child, so Border's content-box inset
                             (BorderThickness eating into the splitter's own 7px Height) doesn't
                             clip it - it can render at a legible size regardless of how thin the
                             splitter itself is. -->
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <iconPacks:PackIconMaterial Kind="DragHorizontalVariant"
                                                     Width="16" Height="16"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     IsHitTestVisible="False">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="{x:Type iconPacks:PackIconMaterial}">
                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}" />
                                    <Setter Property="Visibility" Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type GridSplitter}}, Path=IsMouseOver}" Value="True">
                                            <!-- <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray5}" /> -->
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    Transparent variants: same hit area, drag preview, etc. as their base style, but with no
    visible divider line. Use where the splitter should read as open space between two areas
    of the same panel rather than a boundary between distinct panels (e.g. VerticalGridSplitter
    marking applications vs. profiles).
    -->
    <Style x:Key="VerticalGridSplitterTransparent" TargetType="{x:Type GridSplitter}" BasedOn="{StaticResource VerticalGridSplitter}">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="HorizontalGridSplitterTransparent" TargetType="{x:Type GridSplitter}" BasedOn="{StaticResource HorizontalGridSplitter}">
        <Setter Property="Background" Value="Transparent" />
    </Style>

</ResourceDictionary>