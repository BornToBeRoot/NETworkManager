<UserControl x:Class="NETworkManager.Controls.TracerouteMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
             xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400">
    <UserControl.Resources>
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    </UserControl.Resources>
    <Grid>
        <!-- Cursor=Hand while collapsed hints that clicking this thin strip expands the map
             again (see BorderHost_MouseLeftButtonDown), instead of trying to pan/zoom it. -->
        <Border x:Name="BorderHost"
                Background="{DynamicResource ResourceKey=MahApps.Brushes.Window.Background}"
                ClipToBounds="True"
                MouseWheel="BorderHost_MouseWheel"
                MouseLeftButtonDown="BorderHost_MouseLeftButtonDown"
                MouseLeftButtonUp="BorderHost_MouseLeftButtonUp"
                MouseMove="BorderHost_MouseMove"
                LostMouseCapture="BorderHost_LostMouseCapture"
                SizeChanged="BorderHost_SizeChanged">
            <Border.Style>
                <Style TargetType="{x:Type TypeName=Border}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}}" Value="False">
                            <Setter Property="Cursor" Value="Hand" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <!--
            No explicit Width/Height (and no Left/Top alignment) here on purpose: a Canvas
            never sizes itself to its children, so leaving this at its 1000x500 map-unit size
            made it report that as its own DesiredSize to BorderHost - harmless while
            TracerouteView's MapRow has a fixed pixel Height, but while collapsing that row to
            GridLength.Auto (see TracerouteView's CollapseMapRow), the Grid's Auto-measure
            briefly picked up this raw 500-unit DesiredSize before settling on the (much
            smaller) actual collapsed content, causing a visible "pop taller, then collapse"
            glitch. Defaulting to Stretch instead makes this Canvas's own ActualWidth/Height
            simply follow whatever BorderHost already allocates, which every position on it
            (Canvas.Left/Top in map units, RenderTransformOrigin default of (0,0)) is unaffected
            by, since none of that math depends on the Canvas's own size. This is also what lets
            MapRow settle on just the toggle button's height below while collapsed, instead of 0.
            -->
            <Canvas x:Name="RootCanvas">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="PanTransform" X="0" Y="0" />
                    </TransformGroup>
                </Canvas.RenderTransform>

                <Path x:Name="CountriesPath"
                      Fill="{DynamicResource ResourceKey=MahApps.Brushes.Gray10}"
                      Stroke="{DynamicResource ResourceKey=MahApps.Brushes.Gray8}"
                      StrokeThickness="0.5" />

                <!--
                Cities, labels and hop markers/arrows are all hidden while collapsed: squeezed
                into the thin collapsed strip (see MapRow in TracerouteView.xaml.cs), they read
                as visual noise rather than useful detail - a bare country outline reads as a
                clean, minimal "this is the map" backdrop instead.
                -->
                <Canvas x:Name="CitiesCanvas" Width="1000" Height="500"
                        Visibility="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}" />
                <Canvas x:Name="LabelsCanvas" Width="1000" Height="500"
                        Visibility="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}" />
                <Canvas x:Name="HopsCanvas" Width="1000" Height="500"
                        Visibility="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}" />
            </Canvas>
        </Border>

        <!-- Hidden while collapsed: bottom-aligned, so on the thin collapsed strip it would
             otherwise overlap the top-left toggle button instead of sitting below it. -->
        <TextBlock Text="{x:Static Member=localization:Strings.ScrollToZoomDragToPan}"
                   Style="{StaticResource ResourceKey=InfoTextBlock}"
                   FontSize="11"
                   Margin="10"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Visibility="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}" />

        <!--
        Fixed-position replacement for a WPF ToolTip popup: shown/hidden from code-behind on
        hover of a hop marker or arrow. A floating ToolTip popup could itself trigger a spurious
        MouseLeave on the element underneath it, undoing the hover highlight while the tooltip -
        the very thing telling you you're hovering it - was still open. This has no such problem,
        since it's just a regular element, not a separate popup window.

        Bottom-right (rather than sharing the top-left corner with the toggle button) so it never
        has to fight either overlay button for space - the four corners now each have exactly one
        piece of chrome: toggle (top-left), reset (top-right), zoom/pan hint (bottom-left), this
        panel (bottom-right).
        -->
        <Border x:Name="InfoPanel"
                Background="{DynamicResource ResourceKey=MahApps.Brushes.Window.Background}"
                BorderBrush="{DynamicResource ResourceKey=MahApps.Brushes.Gray8}"
                BorderThickness="1"
                Padding="8,6"
                Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="InfoPanelText"
                       Style="{StaticResource ResourceKey=WrapTextBlock}" />
        </Border>

        <!--
        Doubles as the collapse/expand toggle that used to live in a separate Expander header
        above the map (see TracerouteView.xaml) - always rendered (unlike the rest of the map,
        it doesn't depend on Hops), so it stays clickable even while collapsed, when MapRow
        shrinks down to just this button's own height (see the RootCanvas comment above).
        -->
        <Button HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Click="ButtonToggleExpand_Click"
                Style="{StaticResource ResourceKey=CleanButton}">
            <StackPanel Orientation="Horizontal">
                <Rectangle Width="16" Height="16"
                           VerticalAlignment="Center">
                    <Rectangle.Resources>
                        <VisualBrush x:Key="VisualChevronUp" Stretch="Uniform" Visual="{iconPacks:Material Kind=ChevronUp}" />
                        <VisualBrush x:Key="VisualChevronDown" Stretch="Uniform" Visual="{iconPacks:Material Kind=ChevronDown}" />
                    </Rectangle.Resources>
                    <Rectangle.Style>
                        <Style TargetType="{x:Type TypeName=Rectangle}">
                            <!-- Matches the chevron-direction convention already used by the
                                 app's other Expanders (see ExpanderDownHeader in
                                 ExpanderStyles.xaml): up while collapsed, down while expanded. -->
                            <Setter Property="OpacityMask" Value="{StaticResource ResourceKey=VisualChevronUp}" />
                            <Setter Property="Fill" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray3}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}}" Value="True">
                                    <Setter Property="OpacityMask" Value="{StaticResource ResourceKey=VisualChevronDown}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=Button}}, Path=IsMouseOver}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <TextBlock Margin="4,0,0,0"
                           Text="{x:Static Member=localization:Strings.Map}"
                           FontSize="14"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TypeName=TextBlock}">
                            <Setter Property="Foreground" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray3}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=Button}}, Path=IsMouseOver}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Button>

        <!-- Hidden while collapsed: resetting the pan/zoom of a map you can't currently see
             would be pointless clutter next to the toggle button on the collapsed strip. -->
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="10"
                Click="ButtonResetView_Click"
                Style="{StaticResource ResourceKey=CleanButton}"
                Visibility="{Binding Path=IsExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=UserControl}}, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}">
            <StackPanel Orientation="Horizontal">
                <Rectangle Width="16" Height="16"
                           VerticalAlignment="Center">
                    <Rectangle.OpacityMask>
                        <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=FitToScreenOutline}" />
                    </Rectangle.OpacityMask>
                    <Rectangle.Style>
                        <Style TargetType="{x:Type TypeName=Rectangle}">
                            <Setter Property="Fill" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray3}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=Button}}, Path=IsMouseOver}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <TextBlock Margin="4,0,0,0"
                           Text="{x:Static Member=localization:Strings.Reset}"
                           FontSize="14"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TypeName=TextBlock}">
                            <Setter Property="Foreground" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray3}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=Button}}, Path=IsMouseOver}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
