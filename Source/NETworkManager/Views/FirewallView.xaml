<UserControl
    x:Class="NETworkManager.Views.FirewallView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
    xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
    xmlns:settings="clr-namespace:NETworkManager.Settings;assembly=NETworkManager.Settings"
    xmlns:controls="clr-namespace:NETworkManager.Controls;assembly=NETworkManager.Controls"
    xmlns:firewall="clr-namespace:NETworkManager.Models.Firewall;assembly=NETworkManager.Models"
    xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
    xmlns:wpfHelpers="clr-namespace:NETworkManager.Utilities.WPF;assembly=NETworkManager.Utilities.WPF"
    xmlns:networkManager="clr-namespace:NETworkManager"
    dialogs:DialogParticipation.Register="{Binding}"
    mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:FirewallViewModel}">
    <UserControl.Resources>
        <converters:BooleanReverseToVisibilityCollapsedConverter x:Key="BooleanReverseToVisibilityCollapsedConverter" />
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <converters:FirewallProtocolToStringConverter x:Key="FirewallProtocolToStringConverter" />
        <converters:FirewallRuleDirectionToStringConverter x:Key="FirewallRuleDirectionToStringConverter" />
        <converters:FirewallRuleActionToStringConverter x:Key="FirewallRuleActionToStringConverter" />
        <converters:FirewallInterfaceTypeToStringConverter x:Key="FirewallInterfaceTypeToStringConverter" />
        <converters:FirewallNetworkProfilesToStringConverter x:Key="FirewallNetworkProfilesToStringConverter" />
        <wpfHelpers:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
    </UserControl.Resources>
        <TabControl Style="{StaticResource DefaultTabControl}">
            <TabItem Header="{x:Static localization:Strings.Firewall}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header + Refresh + Search -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource HeaderTextBlock}"
                                   Text="{x:Static localization:Strings.FirewallRules}"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <Button Command="{Binding Path=RefreshCommand}"
                                    Style="{StaticResource CleanButton}"
                                    Margin="0,0,10,0">
                                <Rectangle Width="16" Height="16"
                                           wpfHelpers:ReloadAnimationHelper.IsReloading="{Binding IsRefreshing}">
                                    <Rectangle.OpacityMask>
                                        <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Refresh}" />
                                    </Rectangle.OpacityMask>
                                    <Rectangle.Style>
                                        <Style TargetType="{x:Type Rectangle}">
                                            <Setter Property="Fill" Value="{DynamicResource MahApps.Brushes.Gray3}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource MahApps.Brushes.Gray5}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </Button>
                            <TextBox Width="250"
                                     Text="{Binding RulesSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchTextBox}" />
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: DataGrid -->
                    <controls:MultiSelectDataGrid
                        x:Name="DataGridFirewallRules"
                        Grid.Row="2"
                        ItemsSource="{Binding ResultsView}"
                        SelectedItem="{Binding SelectedResult}"
                        SelectedItemsList="{Binding SelectedResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        wpfHelpers:DataGridHelper.RefreshStarColumnsOnFirstRow="True"
                        RowDetailsVisibilityMode="Collapsed">
                        <controls:MultiSelectDataGrid.InputBindings>
                            <KeyBinding Command="{Binding EditRuleCommand}" Key="F2" />
                            <KeyBinding Command="{Binding DeleteRuleCommand}" Key="Delete" />
                        </controls:MultiSelectDataGrid.InputBindings>
                        <controls:MultiSelectDataGrid.Resources>
                            <ContextMenu x:Key="RowContextMenu" Opened="ContextMenu_Opened" MinWidth="150">
                                <MenuItem Header="{x:Static localization:Strings.EnableRule}"
                                          Command="{Binding Path=EnableRuleCommand}"
                                          Visibility="{Binding Path=SelectedResult.IsEnabled, Converter={StaticResource BooleanReverseToVisibilityCollapsedConverter}}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ToggleSwitchOutline}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static localization:Strings.DisableRule}"
                                          Command="{Binding Path=DisableRuleCommand}"
                                          Visibility="{Binding Path=SelectedResult.IsEnabled, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ToggleSwitchOffOutline}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static localization:Strings.EditRuleDots}"
                                          Command="{Binding Path=EditRuleCommand}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Modern Kind=Edit}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static localization:Strings.DeleteRule}"
                                          Command="{Binding Path=DeleteRuleCommand}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Close}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{x:Static localization:Strings.CopyDots}"
                                          Style="{StaticResource CopyMenuItem}">
                                    <MenuItem Header="{x:Static localization:Strings.Enabled}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.IsEnabled, Converter={StaticResource BooleanToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Name}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.Name}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Direction}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.Direction, Converter={StaticResource FirewallRuleDirectionToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Action}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.Action, Converter={StaticResource FirewallRuleActionToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Protocol}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.Protocol, Converter={StaticResource FirewallProtocolToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.LocalIPAddress}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.LocalAddressesDisplay}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.LocalPort}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.LocalPortsDisplay}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.RemoteIPAddress}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.RemoteAddressesDisplay}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.RemotePort}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.RemotePortsDisplay}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Program}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.ProgramDisplay}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.InterfaceType}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.InterfaceType, Converter={StaticResource FirewallInterfaceTypeToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.NetworkProfiles}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.NetworkProfiles, Converter={StaticResource FirewallNetworkProfilesToStringConverter}}"
                                              Style="{StaticResource CopyMenuItem}" />
                                    <MenuItem Header="{x:Static localization:Strings.Description}"
                                              Command="{Binding Path=CopyDataToClipboardCommand}"
                                              CommandParameter="{Binding Path=SelectedResult.Description}"
                                              Style="{StaticResource CopyMenuItem}" />
                                </MenuItem>
                                <MenuItem Header="{x:Static localization:Strings.ExportDots}"
                                          Command="{Binding Path=ExportCommand}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Export}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                            <ContextMenu x:Key="MultiRowContextMenu" Opened="ContextMenu_Opened" MinWidth="150">
                                <MenuItem Header="{x:Static localization:Strings.ExportDots}"
                                          Command="{Binding ExportCommand}">
                                    <MenuItem.Icon>
                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Export}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </controls:MultiSelectDataGrid.Resources>
                        <controls:MultiSelectDataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource MahApps.Styles.DataGridRow}">
                                <Setter Property="ContextMenu" Value="{StaticResource MultiRowContextMenu}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItems.Count, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGrid}}}" Value="1">
                                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:MultiSelectDataGrid.RowStyle>
                        <controls:MultiSelectDataGrid.Columns>

                            <!-- Expand / collapse row details -->
                            <DataGridTemplateColumn Header="" Width="24" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Click="ExpandRowDetails_OnClick" Style="{StaticResource CleanButton}">
                                            <Rectangle x:Name="ExpandRowDetails" Height="16" Width="16"
                                                       Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ChevronUp}" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Button>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Path=DetailsVisibility, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridRow}}" Value="Visible">
                                                <Setter TargetName="ExpandRowDetails" Property="OpacityMask">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ChevronDown}" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ExpandRowDetails" Property="Fill" Value="{DynamicResource MahApps.Brushes.Gray5}" />
                                            </Trigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Enabled -->
                            <DataGridCheckBoxColumn Header="{x:Static localization:Strings.Enabled}"
                                                    Binding="{Binding (firewall:FirewallRule.IsEnabled)}"
                                                    SortMemberPath="IsEnabled"
                                                    MinWidth="70" />

                            <!-- Name -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.Name}"
                                                Binding="{Binding (firewall:FirewallRule.Name)}"
                                                SortMemberPath="Name"
                                                MinWidth="150" />
                            
                            <!-- Direction -->
                            <DataGridTemplateColumn Header="{x:Static localization:Strings.Direction}"
                                                    SortMemberPath="Direction" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type firewall:FirewallRule}">
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle x:Name="DirectionIcon" Width="16" Height="16"
                                                       Margin="0,0,6,0"
                                                       Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ArrowDown}" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <TextBlock Text="{Binding Direction, Converter={StaticResource FirewallRuleDirectionToStringConverter}}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Direction}" Value="{x:Static firewall:FirewallRuleDirection.Outbound}">
                                                <Setter TargetName="DirectionIcon" Property="OpacityMask">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=ArrowUp}" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Action icon -->
                            <DataGridTemplateColumn Header="" SortMemberPath="Action"
                                                    Width="24" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type firewall:FirewallRule}">
                                        <Rectangle x:Name="ActionIcon" Width="16" Height="16"
                                                   Fill="#b95353">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Close}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding (firewall:FirewallRule.Action)}" Value="{x:Static firewall:FirewallRuleAction.Allow}">
                                                <Setter TargetName="ActionIcon" Property="Fill" Value="#badc58" />
                                                <Setter TargetName="ActionIcon" Property="OpacityMask">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Check}" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Action text -->
                            <DataGridTemplateColumn Header="{x:Static localization:Strings.Action}"
                                                    SortMemberPath="Action" MinWidth="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type firewall:FirewallRule}">
                                        <TextBlock x:Name="ActionText"
                                                   Text="{Binding (firewall:FirewallRule.Action), Converter={StaticResource FirewallRuleActionToStringConverter}}"
                                                   Foreground="#b95353"
                                                   VerticalAlignment="Center" />
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding (firewall:FirewallRule.Action)}" Value="{x:Static firewall:FirewallRuleAction.Allow}">
                                                <Setter TargetName="ActionText" Property="Foreground" Value="#badc58" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Protocol -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.Protocol}"
                                                Binding="{Binding (firewall:FirewallRule.Protocol), Converter={StaticResource FirewallProtocolToStringConverter}}"
                                                SortMemberPath="Protocol"
                                                MinWidth="80" />

                            <!-- Local IP addresses -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.LocalIPAddress}"
                                                SortMemberPath="LocalAddressesDisplay"
                                                MinWidth="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="(firewall:FirewallRule.LocalAddressesDisplay)">
                                        <Binding.TargetNullValue>
                                            <x:Static Member="localization:Strings.Any" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>

                            <!-- Local ports -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.LocalPort}"
                                                SortMemberPath="LocalPortsDisplay"
                                                MinWidth="100">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="(firewall:FirewallRule.LocalPortsDisplay)">
                                        <Binding.TargetNullValue>
                                            <x:Static Member="localization:Strings.Any" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            
                            <!-- Remote IP addresses -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.RemoteIPAddress}"
                                                SortMemberPath="RemoteAddressesDisplay"
                                                MinWidth="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="(firewall:FirewallRule.RemoteAddressesDisplay)">
                                        <Binding.TargetNullValue>
                                            <x:Static Member="localization:Strings.Any" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>

                            <!-- Remote ports -->
                            <DataGridTextColumn Header="{x:Static localization:Strings.RemotePort}"
                                                SortMemberPath="RemotePortsDisplay"
                                                MinWidth="100"
                                                Width="*">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="(firewall:FirewallRule.RemotePortsDisplay)">
                                        <Binding.TargetNullValue>
                                            <x:Static Member="localization:Strings.Any" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>

                        </controls:MultiSelectDataGrid.Columns>

                        <!-- Expanded row details -->
                        <controls:MultiSelectDataGrid.RowDetailsTemplate>
                            <DataTemplate DataType="{x:Type firewall:FirewallRule}">
                                <Border BorderThickness="1,0,1,1" Background="{DynamicResource MahApps.Brushes.Window.Background}">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridRow}}" Value="False">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray8}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="36,10,10,10">
                                        <Grid.Resources>
                                            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource TextBlockAsTextBox}">
                                                <Setter Property="ContextMenu" Value="{StaticResource CopyContextMenu}" />
                                            </Style>
                                        </Grid.Resources>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="150" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" MinWidth="200" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="Auto" MinWidth="150" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" MinWidth="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="5" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Program | Interface type -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{x:Static localization:Strings.Program}"
                                                   Style="{StaticResource InfoTextBlock}" />
                                        <TextBox Grid.Row="0" Grid.Column="2">
                                            <TextBox.Text>
                                                <Binding Path="(firewall:FirewallRule.ProgramDisplay)" Mode="OneWay">
                                                    <Binding.TargetNullValue>
                                                        <x:Static Member="localization:Strings.Any" />
                                                    </Binding.TargetNullValue>
                                                </Binding>
                                            </TextBox.Text>
                                        </TextBox>

                                        <TextBlock Grid.Row="0" Grid.Column="4"
                                                   Text="{x:Static localization:Strings.InterfaceType}"
                                                   Style="{StaticResource InfoTextBlock}" />
                                        <TextBox Grid.Row="0" Grid.Column="6"
                                                 Text="{Binding (firewall:FirewallRule.InterfaceType), Mode=OneWay, Converter={StaticResource FirewallInterfaceTypeToStringConverter}}" />

                                        <!-- Row 2: Network profiles | Description -->
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{x:Static localization:Strings.NetworkProfiles}"
                                                   Style="{StaticResource InfoTextBlock}" />
                                        <TextBox Grid.Row="2" Grid.Column="2"
                                                 Text="{Binding (firewall:FirewallRule.NetworkProfiles), Mode=OneWay, Converter={StaticResource FirewallNetworkProfilesToStringConverter}}" />

                                        <TextBlock Grid.Row="2" Grid.Column="4"
                                                   Text="{x:Static localization:Strings.Description}"
                                                   Style="{StaticResource InfoTextBlock}" />
                                        <TextBox Grid.Row="2" Grid.Column="6"
                                                 Text="{Binding (firewall:FirewallRule.Description), Mode=OneWay}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </controls:MultiSelectDataGrid.RowDetailsTemplate>
                    </controls:MultiSelectDataGrid>

                    <!-- Row 4: Status message -->
                    <Grid Grid.Row="4" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <networkManager:LoadingIndicator Grid.Column="0" IsActive="True"
                                                         Style="{DynamicResource ResourceKey=LoadingIndicatorPulseStyle}"
                                                         Visibility="{Binding Path=IsRefreshing, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}"
                                                         Width="24" Height="24"
                                                         SpeedRatio="1" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource ResourceKey=AccentTextBlock}"
                                   Visibility="{Binding Path=IsStatusMessageDisplayed, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}"
                                   Text="{Binding Path=StatusMessage}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Row 6: Bottom buttons -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <WrapPanel Grid.Column="0"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left">
                            <Button Command="{Binding Path=OpenWindowsFirewallCommand}"
                                    Style="{StaticResource ImageWithTextButton}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Style="{StaticResource ButtonWithImageRectangle}">
                                        <Rectangle.OpacityMask>
                                            <VisualBrush Stretch="Uniform" Visual="{iconPacks:FontAwesome Kind=WindowsBrands}" />
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Static localization:Strings.WindowsFirewallSettings}"
                                               Style="{StaticResource ButtonWithImageTextBlock}" />
                                </Grid>
                            </Button>
                        </WrapPanel>
                        <WrapPanel Grid.Column="2"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right">
                            <Button Command="{Binding Path=AddRuleCommand}" Style="{StaticResource ImageWithTextButton}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Style="{StaticResource ButtonWithImageRectangle}">
                                        <Rectangle.OpacityMask>
                                            <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Plus}" />
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Static localization:Strings.AddRuleDots}"
                                               Style="{StaticResource ButtonWithImageTextBlock}" />
                                </Grid>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <!-- Row 7: Admin note -->
                    <Grid Grid.Row="7"
                          Background="{DynamicResource MahApps.Brushes.Gray10}"
                          Visibility="{Binding Source={x:Static settings:ConfigurationManager.Current}, Path=IsAdmin, Converter={StaticResource BooleanReverseToVisibilityCollapsedConverter}}"
                          Margin="0,10,0,0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                    Margin="10">
                            <TextBlock Text="{x:Static localization:Strings.FirewallAdminMessage}"
                                       Style="{StaticResource MessageTextBlock}"
                                       Margin="0,0,0,10" />
                            <Button Command="{Binding RestartAsAdminCommand}"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource ImageWithTextButton}">
                                <Button.Content>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Width="20" Height="20"
                                                   Margin="10,5,0,5"
                                                   Fill="{DynamicResource MahApps.Brushes.Gray3}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Shield}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Static localization:Strings.RestartAsAdmin}"
                                                   FontSize="14"
                                                   Margin="10,5"
                                                   TextAlignment="Center" />
                                    </Grid>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
</UserControl>

