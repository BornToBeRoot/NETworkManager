<UserControl x:Class="NETworkManager.Views.PowerShellSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:validators="clr-namespace:NETworkManager.Validators;assembly=NETworkManager.Validators"
             xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
             xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:PowerShellSettingsViewModel}">
    <StackPanel>
        <TextBlock Text="{x:Static localization:Strings.PowerShell}" Style="{StaticResource HeaderTextBlock}" />
        <TextBlock Text="{x:Static localization:Strings.FilePath}" Style="{DynamicResource DefaultTextBlock}"
                   Margin="0,0,0,10" />
        <TextBox x:Name="TextBoxApplicationFilePath" Width="500" HorizontalAlignment="Left"
                 mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePowerShellPath}"
                 Style="{StaticResource BrowseFolderTextBox}"
                 mah:TextBoxHelper.ButtonCommand="{Binding BrowseFileCommand}" AllowDrop="True"
                 Drop="TextBoxApplicationFilePath_Drop" PreviewDragOver="TextBoxApplicationFilePath_PreviewDragOver"
                 Margin="0,0,0,10">
            <TextBox.Text>
                <Binding Path="ApplicationFilePath" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:EmptyValidator ValidatesOnTargetUpdated="True" />
                        <validators:FileExistsValidator ValidatesOnTargetUpdated="True" />
                        <validators:PowerShellPathValidator ValidatesOnTargetUpdated="True" />
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <Button Content="{x:Static localization:Strings.Configure}" Command="{Binding ConfigureCommand}"
                IsEnabled="{Binding IsConfigured}" Style="{StaticResource DefaultButton}" HorizontalAlignment="Left"
                Margin="0,0,0,10" />
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Style="{StaticResource InfoImageRectangle}" Width="24" Height="24"
                       HorizontalAlignment="Right" />
            <TextBlock Grid.Column="2"
                       Text="{x:Static localization:Strings.PowerShellConsoleColorCanBeChangedUnderSettingsGeneralApperance}"
                       TextWrapping="Wrap" Style="{StaticResource InfoTextBlock}" />
        </Grid>
        <TextBlock Text="{x:Static localization:Strings.Command}" Style="{DynamicResource DefaultTextBlock}"
                   Margin="0,0,0,10" />
        <TextBox Width="250" Text="{Binding Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 HorizontalAlignment="Left" Style="{StaticResource DefaultTextBox}" Margin="0,0,0,10" />
        <TextBlock Text="{x:Static localization:Strings.AdditionalCommandLine}"
                   Style="{DynamicResource DefaultTextBlock}" Margin="0,0,0,10" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="250" Text="{Binding AdditionalCommandLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalAlignment="Left" Style="{StaticResource DefaultTextBox}" />
            <Rectangle Width="24" Height="24" Style="{StaticResource HelpImageRectangle}" Margin="10,0,0,0">
                <Rectangle.ToolTip>
                    <ToolTip Style="{StaticResource DefaultToolTip}" MaxWidth="320">
                        <StackPanel>
                            <TextBlock Text="{x:Static localization:Strings.HelpMessage_ProfileHostPlaceholder}"
                                       Style="{StaticResource DefaultTextBlock}"
                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                            <Border BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                                    BorderThickness="1" CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.Resources>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Padding" Value="6,3" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </Grid.Resources>

                                    <!-- Header row -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{x:Static localization:Strings.Placeholder}" FontWeight="Bold" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{x:Static localization:Strings.Description}" FontWeight="Bold" />
                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0" Height="1"
                                               Fill="{DynamicResource MahApps.Brushes.Gray8}" />

                                    <!-- Placeholder -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{}{{Host}}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{x:Static localization:Strings.Host}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ToolTip>
                </Rectangle.ToolTip>
            </Rectangle>
        </StackPanel>
        <TextBlock Text="{x:Static localization:Strings.ExecutionPolicy}" Style="{DynamicResource DefaultTextBlock}"
                   Margin="0,0,0,10" />
        <ComboBox Width="250" ItemsSource="{Binding ExecutionPolicies}" SelectedItem="{Binding ExecutionPolicy}"
                  HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>