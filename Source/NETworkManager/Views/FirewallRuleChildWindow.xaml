<simpleChildWindow:ChildWindow x:Class="NETworkManager.Views.FirewallRuleChildWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:validators="clr-namespace:NETworkManager.Validators;assembly=NETworkManager.Validators"
             xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
             xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
             xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
             xmlns:simpleChildWindow="clr-namespace:MahApps.Metro.SimpleChildWindow;assembly=MahApps.Metro.SimpleChildWindow"
             CloseButtonCommand="{Binding Path=CancelCommand}"
             Style="{StaticResource DefaultChildWindow}"
             ChildWindowMaxHeight="700"
             Loaded="ChildWindow_OnLoaded"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:FirewallRuleViewModel}">
    <simpleChildWindow:ChildWindow.Resources>
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
        <converters:FirewallProtocolToStringConverter x:Key="FirewallProtocolToStringConverter" />
        <converters:FirewallRuleDirectionToStringConverter x:Key="FirewallRuleDirectionToStringConverter" />
        <converters:FirewallRuleActionToStringConverter x:Key="FirewallRuleActionToStringConverter" />
        <converters:FirewallInterfaceTypeToStringConverter x:Key="FirewallInterfaceTypeToStringConverter" />
    </simpleChildWindow:ChildWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.Resources>
                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenterTextBlock}" />
                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource DefaultTextBox}" />
                    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource DefaultCheckBox}" />
                    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource DefaultComboBox}" />
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="{x:Static localization:Strings.Name}" />
                <TextBox x:Name="TextBoxName"
                         Grid.Column="2" Grid.Row="0"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleFirewallRuleName}">
                    <TextBox.Text>
                        <Binding Path="Name" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Enabled -->
                <TextBlock Grid.Column="0" Grid.Row="2"
                           Text="{x:Static localization:Strings.Enabled}" />
                <mah:ToggleSwitch Grid.Column="2" Grid.Row="2" OnContent="" OffContent=""
                                  IsOn="{Binding IsEnabled}" />

                <!-- Description -->
                <TextBlock Grid.Column="0" Grid.Row="4"
                           Text="{x:Static localization:Strings.Description}" />
                <TextBox Grid.Column="2" Grid.Row="4"
                         Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Direction -->
                <TextBlock Grid.Column="0" Grid.Row="6"
                           Text="{x:Static localization:Strings.Direction}" />
                <ComboBox Grid.Column="2" Grid.Row="6"
                          ItemsSource="{Binding Directions}"
                          SelectedItem="{Binding Direction, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FirewallRuleDirectionToStringConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Action -->
                <TextBlock Grid.Column="0" Grid.Row="8"
                           Text="{x:Static localization:Strings.Action}" />
                <ComboBox Grid.Column="2" Grid.Row="8"
                          ItemsSource="{Binding Actions}"
                          SelectedItem="{Binding Action, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FirewallRuleActionToStringConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Protocol -->
                <TextBlock Grid.Column="0" Grid.Row="10"
                           Text="{x:Static localization:Strings.Protocol}" />
                <ComboBox Grid.Column="2" Grid.Row="10"
                          ItemsSource="{Binding Protocols}"
                          SelectedItem="{Binding Protocol, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FirewallProtocolToStringConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Local ports (TCP/UDP only) -->
                <TextBlock Grid.Column="0" Grid.Row="12"
                           Text="{x:Static localization:Strings.LocalPorts}"
                           Visibility="{Binding PortsVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                <TextBox x:Name="TextBoxLocalPorts"
                         Grid.Column="2" Grid.Row="12"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePorts}"
                         Visibility="{Binding PortsVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                    <TextBox.Text>
                        <Binding Path="LocalPorts" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyOrPortRangeValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Remote ports (TCP/UDP only) -->
                <TextBlock Grid.Column="0" Grid.Row="14"
                           Text="{x:Static localization:Strings.RemotePorts}"
                           Visibility="{Binding PortsVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                <TextBox x:Name="TextBoxRemotePorts"
                         Grid.Column="2" Grid.Row="14"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePorts}"
                         Visibility="{Binding PortsVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                    <TextBox.Text>
                        <Binding Path="RemotePorts" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyOrPortRangeValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Local addresses -->
                <TextBlock Grid.Column="0" Grid.Row="16"
                           Text="{x:Static localization:Strings.LocalAddresses}" />
                <TextBox x:Name="TextBoxLocalAddresses"
                         Grid.Column="2" Grid.Row="16"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleFirewallAddresses}">
                    <TextBox.Text>
                        <Binding Path="LocalAddresses" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyOrFirewallAddressValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Remote addresses -->
                <TextBlock Grid.Column="0" Grid.Row="18"
                           Text="{x:Static localization:Strings.RemoteAddresses}" />
                <TextBox x:Name="TextBoxRemoteAddresses"
                         Grid.Column="2" Grid.Row="18"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleFirewallAddresses}">
                    <TextBox.Text>
                        <Binding Path="RemoteAddresses" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyOrFirewallAddressValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Program -->
                <TextBlock Grid.Column="0" Grid.Row="20"
                           Text="{x:Static localization:Strings.Program}" />
                <TextBox x:Name="TextBoxProgram"
                         Grid.Column="2" Grid.Row="20"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePowerShellPath}">
                    <TextBox.Text>
                        <Binding Path="Program" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:EmptyOrFileExistsValidator ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <!-- Interface type -->
                <TextBlock Grid.Column="0" Grid.Row="22"
                           Text="{x:Static localization:Strings.InterfaceType}" />
                <ComboBox Grid.Column="2" Grid.Row="22"
                          ItemsSource="{Binding InterfaceTypes}"
                          SelectedItem="{Binding InterfaceType, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FirewallInterfaceTypeToStringConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Network profiles -->
                <TextBlock Grid.Column="0" Grid.Row="24"
                           Text="{x:Static localization:Strings.NetworkProfiles}" />
                <WrapPanel Grid.Column="2" Grid.Row="24" Orientation="Horizontal">
                    <CheckBox Content="{x:Static localization:Strings.Domain}"
                              IsChecked="{Binding NetworkProfileDomain}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="{x:Static localization:Strings.Private}"
                              IsChecked="{Binding NetworkProfilePrivate}"
                              Margin="0,0,10,0" />
                    <CheckBox Content="{x:Static localization:Strings.Public}"
                              IsChecked="{Binding NetworkProfilePublic}" />
                </WrapPanel>
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static Member=localization:Strings.OK}" Command="{Binding Path=OKCommand}"
                    IsDefault="True" Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource HighlightedButton}">
                        <Setter Property="IsEnabled" Value="False" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxName}"
                                               Value="False" />
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxLocalPorts}"
                                               Value="False" />
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxRemotePorts}"
                                               Value="False" />
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxLocalAddresses}"
                                               Value="False" />
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxRemoteAddresses}"
                                               Value="False" />
                                    <Condition Binding="{Binding Path=(Validation.HasError), ElementName=TextBoxProgram}"
                                               Value="False" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsEnabled" Value="True" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="{x:Static Member=localization:Strings.Cancel}" Command="{Binding Path=CancelCommand}"
                    IsCancel="True" Style="{StaticResource DefaultButton}" />
        </StackPanel>
    </Grid>
</simpleChildWindow:ChildWindow>