<simpleChildWindow:ChildWindow x:Class="NETworkManager.Views.ImportProfilesResultChildWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:validators="clr-namespace:NETworkManager.Validators;assembly=NETworkManager.Validators"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
             xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
             xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:simpleChildWindow="clr-namespace:MahApps.Metro.SimpleChildWindow;assembly=MahApps.Metro.SimpleChildWindow"
             CloseButtonCommand="{Binding Path=CancelCommand}"
             Style="{StaticResource ResourceKey=DefaultChildWindow}"
             Loaded="ChildWindow_OnLoaded"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:ImportProfilesResultViewModel}">
    <simpleChildWindow:ChildWindow.Resources>
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    </simpleChildWindow:ChildWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Body -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Left header + Search -->
            <Grid Grid.Column="0" Grid.Row="0">
                <TextBlock Text="{x:Static Member=localization:Strings.Hosts}"
                           Style="{StaticResource ResourceKey=HeaderTextBlock}" />
                <TextBox x:Name="TextBoxSearch"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Width="250"
                         Text="{Binding Path=Search, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ResourceKey=SearchTextBox}" />
            </Grid>
     
            <!-- Left: DataGrid + buttons -->
            <Grid Grid.Column="0" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Path=CandidatesView}"
                          d:ItemsSource="{d:DesignInstance viewModels:ImportCandidateItem, IsDesignTimeCreatable=False}"
                          CanUserResizeRows="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ResourceKey=DefaultDataGrid}"
                          PreviewKeyDown="DataGrid_OnPreviewKeyDown">
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type TypeName=DataGridRow}" BasedOn="{StaticResource ResourceKey=MahApps.Styles.DataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=DataContext.IsSearching, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TypeName=DataGrid}}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type TypeName=viewModels:ImportCandidateItem}">
                                    <CheckBox IsChecked="{Binding Path=IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Focusable="False" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn MinWidth="150"
                                               Header="{x:Static Member=localization:Strings.Name}"
                                               IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type TypeName=viewModels:ImportCandidateItem}">
                                    <TextBlock Text="{Binding Path=Name}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*"
                                               Header="{x:Static Member=localization:Strings.Host}"
                                               IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type TypeName=viewModels:ImportCandidateItem}">
                                    <TextBlock Text="{Binding Path=Host}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="Auto" Header="{x:Static Member=localization:Strings.Status}" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type TypeName=viewModels:ImportCandidateItem}">
                                    <StackPanel Orientation="Horizontal" Margin="6,0">
                                        <Rectangle x:Name="StatusIcon" Width="12" Height="12"
                                                   Fill="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}"
                                                   Margin="0,0,4,0">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Plus}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock x:Name="StatusText"
                                                   Text="{x:Static Member=localization:Strings.ImportProfiles_StatusNew}"
                                                   Foreground="{DynamicResource ResourceKey=MahApps.Brushes.Gray5}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Path=AlreadyExists}" Value="True">
                                            <Setter TargetName="StatusIcon" Property="Fill" Value="#badc58" />
                                            <Setter TargetName="StatusIcon" Property="OpacityMask">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=Check}" />
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="StatusText" Property="Text" Value="{x:Static Member=localization:Strings.ImportProfiles_StatusImported}" />
                                            <Setter TargetName="StatusText" Property="Foreground" Value="#badc58" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=CanImport}" Value="False">
                                            <Setter TargetName="StatusIcon" Property="Fill" Value="#b95353" />
                                            <Setter TargetName="StatusIcon" Property="OpacityMask">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="Uniform" Visual="{iconPacks:Material Kind=AlertOutline}" />
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="StatusText" Property="Text" Value="{x:Static Member=localization:Strings.ImportProfiles_StatusNoHost}" />
                                            <Setter TargetName="StatusText" Property="Foreground" Value="#b95353" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <mah:ProgressRing Grid.Row="0"
                                  Height="50" Width="50"
                                  IsActive="{Binding Path=IsSearching}" />

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="{x:Static Member=localization:Strings.SelectAll}"
                            Command="{Binding Path=SelectAllCommand}"
                            Style="{StaticResource ResourceKey=DefaultButton}"
                            Margin="0,0,10,0" />
                    <Button Content="{x:Static Member=localization:Strings.DeselectAll}"
                            Command="{Binding Path=DeselectAllCommand}"
                            Style="{StaticResource ResourceKey=DefaultButton}" />
                </StackPanel>
            </Grid>

            <!-- Vertical separator -->
            <Rectangle Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                       Fill="{DynamicResource ResourceKey=MahApps.Brushes.Gray8}"
                       Width="1" />
            
            <!-- Right header -->
            <TextBlock Grid.Column="2" Grid.Row="0"
                       Text="{x:Static Member=localization:Strings.Applications}"
                       Style="{StaticResource ResourceKey=HeaderTextBlock}" />

            <!-- Right: Options -->
            <Grid Grid.Column="2" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- Tool checkboxes -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Path=ApplicationOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type TypeName=viewModels:ImportApplicationToggleItem}">
                                <CheckBox Content="{Binding Path=DisplayName}"
                                          IsChecked="{Binding Path=IsEnabled}"
                                          Style="{StaticResource ResourceKey=DefaultCheckBox}"
                                          Margin="0,0,0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Options header -->
                <TextBlock Grid.Row="2"
                           Text="{x:Static Member=localization:Strings.Options}"
                           Style="{StaticResource ResourceKey=HeaderTextBlock}" />
                
                <!-- Options: Group + Skip duplicates -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0"
                               Text="{x:Static Member=localization:Strings.Group}"
                               Style="{StaticResource ResourceKey=DefaultTextBlock}"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="ComboBoxTargetGroup" Grid.Column="2" Grid.Row="0"
                              Style="{StaticResource ResourceKey=EditableComboBox}"
                              ItemsSource="{Binding Path=GroupNames}"
                              mah:TextBoxHelper.Watermark="{x:Static Member=localization:Strings.ExistingOrNewGroupDots}">
                        <ComboBox.Text>
                            <Binding Path="GroupName" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:EmptyValidator ValidatesOnTargetUpdated="True" />
                                    <validators:GroupNameValidator ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </ComboBox.Text>
                    </ComboBox>

                    <TextBlock Grid.Column="0" Grid.Row="2"
                               Text="{x:Static Member=localization:Strings.SkipAlreadyImported}"
                               Style="{StaticResource ResourceKey=DefaultTextBlock}"
                               VerticalAlignment="Center" />
                    <mah:ToggleSwitch Grid.Column="2" Grid.Row="2"
                                      OnContent="" OffContent=""
                                      IsOn="{Binding Path=SkipDuplicates}" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}"
                       Visibility="{Binding Path=IsStatusMessageDisplayed, Converter={StaticResource ResourceKey=BooleanToVisibilityCollapsedConverter}}"
                       Style="{StaticResource ResourceKey=AccentTextBlock}"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="{x:Static Member=localization:Strings.Back}"
                        Command="{Binding Path=BackCommand}"
                        Style="{StaticResource ResourceKey=DefaultButton}" Margin="0,0,10,0" />
                <Button Content="{x:Static Member=localization:Strings.Import}"
                        Command="{Binding Path=ImportCommand}"
                        IsDefault="True" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="{x:Type TypeName=Button}" BasedOn="{StaticResource ResourceKey=HighlightedButton}">
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding ElementName=ComboBoxTargetGroup, Path=(Validation.HasError)}"
                                    Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=HasAnyCandidateSelected}" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=HasAnyEnabledApplication}" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{x:Static Member=localization:Strings.Cancel}"
                        Command="{Binding Path=CancelCommand}" IsCancel="True"
                        Style="{StaticResource ResourceKey=DefaultButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</simpleChildWindow:ChildWindow>