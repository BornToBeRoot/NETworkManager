<simpleChildWindow:ChildWindow x:Class="NETworkManager.Views.ImportAdComputersChildWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:validators="clr-namespace:NETworkManager.Validators;assembly=NETworkManager.Validators"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
             xmlns:wpfHelpers="clr-namespace:NETworkManager.Utilities.WPF;assembly=NETworkManager.Utilities.WPF"
             xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:networkManager="clr-namespace:NETworkManager"
             xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
             xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
             xmlns:simpleChildWindow="clr-namespace:MahApps.Metro.SimpleChildWindow;assembly=MahApps.Metro.SimpleChildWindow"
             CloseButtonCommand="{Binding CancelCommand}"
             Style="{StaticResource DefaultChildWindow}"
             Loaded="ChildWindow_OnLoaded"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:ImportAdComputersViewModel}">
    <simpleChildWindow:ChildWindow.Resources>
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    </simpleChildWindow:ChildWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenterTextBlock}" />
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search base -->
            <TextBlock Grid.Column="0" Grid.Row="0" 
                       Text="{x:Static localization:Strings.ActiveDirectorySearchBase}" />
            <TextBox x:Name="TextBoxLdapSearchBase" Grid.Column="2" Grid.Row="0"
                     mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ActiveDirectorySearchBase}"
                     Style="{StaticResource DefaultTextBox}">
                <TextBox.Text>
                    <Binding Path="LdapSearchBase" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:LdapSearchBaseValidator ValidatesOnTargetUpdated="True" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <!-- Server -->
            <TextBlock Grid.Column="0" Grid.Row="2"
                       Text="{x:Static localization:Strings.LdapServer}" />
            <TextBox x:Name="TextBoxLdapServer"
                     Grid.Column="2" Grid.Row="2"
                     mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleDomain}"
                     Style="{StaticResource DefaultTextBox}">
                <TextBox.Text>
                    <Binding Path="LdapServer" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:EmptyOrIPAddressOrHostnameValidator ValidatesOnTargetUpdated="True" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>
            <Rectangle Grid.Column="3" Grid.Row="2"
                       Width="24" Height="24"
                       ToolTip="{x:Static localization:Strings.ActiveDirectoryNonDomainHint}"
                       Style="{StaticResource HelpImageRectangle}" 
                       Margin="10,0,0,0">
                <Rectangle.Resources>
                    <Style TargetType="{x:Type ToolTip}" BasedOn="{StaticResource HelpToolTip}" />
                </Rectangle.Resources>
            </Rectangle>

            <!-- Port -->
            <TextBlock Grid.Column="0" Grid.Row="4" Text="{x:Static localization:Strings.LdapPort}" />
            <TextBox x:Name="TextBoxLdapPort" Grid.Column="2" Grid.Row="4"
                     HorizontalAlignment="Left" Width="120"
                     mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleActiveDirectoryPort}"
                     Style="{StaticResource DefaultTextBox}">
                <TextBox.Text>
                    <Binding Path="LdapPort" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:PortValidator ValidatesOnTargetUpdated="True" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <!-- SSL -->
            <TextBlock Grid.Column="0" Grid.Row="6"
                       Text="{x:Static localization:Strings.UseSsl}" />
            <mah:ToggleSwitch Grid.Column="2" Grid.Row="6"
                              OnContent="" OffContent=""
                              IsOn="{Binding UseSsl}" />

            <!-- Authentication -->
            <TextBlock Grid.Column="0" Grid.Row="8"
                       Text="{x:Static localization:Strings.Authentication}" />
            <StackPanel Grid.Column="2" Grid.Row="8" 
                        Orientation="Vertical">
                <RadioButton GroupName="AdImportAuth"
                             Content="{x:Static localization:Strings.UseCurrentWindowsCredentials}"
                             IsChecked="{Binding IsCurrentUserAuth, Mode=TwoWay}"
                             Style="{StaticResource DefaultRadioButton}" 
                             Margin="0,0,0,5" />
                <RadioButton GroupName="AdImportAuth"
                             Content="{x:Static localization:Strings.UseTheseCredentials}"
                             IsChecked="{Binding IsCustomAuth, Mode=TwoWay}"
                             Style="{StaticResource DefaultRadioButton}" />
            </StackPanel>

            <!-- Username (only when custom auth) -->
            <TextBlock Grid.Column="0" Grid.Row="10" 
                       Text="{x:Static localization:Strings.Username}"
                       Visibility="{Binding IsCustomAuth, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            <TextBox x:Name="TextBoxUsername" Grid.Column="2" Grid.Row="10"
                     Style="{StaticResource DefaultTextBox}"
                     mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleUsername}"
                     Visibility="{Binding IsCustomAuth, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                <TextBox.Text>
                    <Binding Path="Username" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:WindowsUsernameValidator ValidatesOnTargetUpdated="True" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <!-- Password (only when custom auth) -->
            <TextBlock Grid.Column="0" Grid.Row="12" Text="{x:Static localization:Strings.Password}"
                       Visibility="{Binding IsCustomAuth, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            <PasswordBox Grid.Column="2" Grid.Row="12"
                         Style="{StaticResource DefaultPasswordBox}"
                         mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePassword}"
                         Visibility="{Binding IsCustomAuth, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                <interactivity:Interaction.Behaviors>
                    <wpfHelpers:PasswordBoxBindingBehavior
                        Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </interactivity:Interaction.Behaviors>
            </PasswordBox>

            <!-- Exclude disabled -->
            <TextBlock Grid.Column="0" Grid.Row="14"
                       Text="{x:Static localization:Strings.ExcludeDisabledAccounts}" />
            <mah:ToggleSwitch Grid.Column="2" Grid.Row="14" OnContent="" OffContent=""
                              IsOn="{Binding ExcludeDisabledAccounts}" />

            <!-- Additional LDAP filter -->
            <TextBlock Grid.Column="0" Grid.Row="16"
                       Text="{x:Static localization:Strings.ActiveDirectoryAdditionalLdapFilter}" />
            <TextBox x:Name="TextBoxAdditionalLdapFilter" Grid.Column="2" Grid.Row="16"
                     mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExampleActiveDirectorySearchFilter}"
                     Style="{StaticResource DefaultTextBox}">
                <TextBox.Text>
                    <Binding Path="AdditionalLdapFilter" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validators:EmptyOrLdapFilterValidator ValidatesOnTargetUpdated="True" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <networkManager:LoadingIndicator Grid.Column="0" IsActive="True"
                                                 Style="{DynamicResource ResourceKey=LoadingIndicatorPulseStyle}"
                                                 Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                                                 Width="24" Height="24"
                                                 SpeedRatio="1" Margin="0,0,10,0" />
                <TextBlock Grid.Column="1"
                           Style="{StaticResource AccentTextBlock}"
                           Visibility="{Binding IsStatusMessageDisplayed, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="{x:Static localization:Strings.Search}" Command="{Binding SearchCommand}"
                        IsDefault="True" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource HighlightedButton}">
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding ElementName=TextBoxLdapSearchBase, Path=(Validation.HasError)}"
                                    Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger
                                    Binding="{Binding ElementName=TextBoxLdapServer, Path=(Validation.HasError)}"
                                    Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger
                                    Binding="{Binding ElementName=TextBoxLdapPort, Path=(Validation.HasError)}"
                                    Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger
                                    Binding="{Binding ElementName=TextBoxAdditionalLdapFilter, Path=(Validation.HasError)}"
                                    Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCustomAuth}" Value="True" />
                                        <Condition
                                            Binding="{Binding ElementName=TextBoxUsername, Path=(Validation.HasError)}"
                                            Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCustomAuth}" Value="True" />
                                        <Condition Binding="{Binding IsPasswordEmpty}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{x:Static localization:Strings.Cancel}" Command="{Binding CancelCommand}"
                        IsCancel="True" Style="{StaticResource DefaultButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</simpleChildWindow:ChildWindow>
