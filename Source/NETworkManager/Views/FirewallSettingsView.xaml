<UserControl
    x:Class="NETworkManager.Views.FirewallSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:viewModels="clr-namespace:NETworkManager.ViewModels"
    xmlns:localization="clr-namespace:NETworkManager.Localization.Resources;assembly=NETworkManager.Localization"
    xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
    xmlns:validators="clr-namespace:NETworkManager.Validators;assembly=NETworkManager.Validators"
    xmlns:converters="clr-namespace:NETworkManager.Converters;assembly=NETworkManager.Converters"
    dialogs:DialogParticipation.Register="{Binding}"
    mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModels:FirewallSettingsViewModel}">
    <UserControl.Resources>
        <converters:EmptyToIntMaxValueConverter x:Key="EmptyToNegativeConverter"/>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock 
            Text="{x:Static localization:Strings.Firewall}" 
            Style="{StaticResource HeaderTextBlock}" />
        <TextBlock
            Text="{x:Static localization:Strings.MaxLengthOfPortEntries}"
            Style="{StaticResource DefaultTextBlock}"
            Margin="0,0,0,10" />
        <TextBox 
            Width="80" HorizontalAlignment="Left" Style="{StaticResource DefaultTextBox}"
            mah:TextBoxHelper.Watermark="{x:Static localization:StaticStrings.ExamplePort22}"
            Margin="0 0 0 10">
            <TextBox.Text>
                <Binding 
                    Path="MaxLengthHistory" 
                    Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"
                    Converter="{StaticResource EmptyToNegativeConverter}">
                    <Binding.ValidationRules>
                        <validators:EmptyOrInt32Validator ValidatesOnTargetUpdated="True"/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <mah:ToggleSwitch 
            Header="{x:Static localization:Strings.CombineLocalAndRemotePortHistory}"
            IsOn="{Binding CombinePortHistory}" Margin="0,0,0,10" />
        <mah:ToggleSwitch 
            Header="{x:Static localization:Strings.UseWindowsPortListSyntax}"
            IsOn="{Binding UseWindowsPortSyntax}" Margin="0,0,0,10" />
        <TextBlock 
            Text="{x:Static localization:Strings.ErasePortHistory}" 
            Style="{StaticResource BoldTextBlock}" />
        <StackPanel Orientation="Horizontal" Margin="10">
                <Button
                    Margin="0,0,10,0"
                    Command="{Binding Path=ClearLocalPortHistoryCommand}"
                    Style="{StaticResource ImageWithTextButton}"
                    IsEnabled="{Binding LocalPortsHaveItems, UpdateSourceTrigger=Explicit}">
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Style="{StaticResource ButtonWithImageRectangle}">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Stretch="Uniform" Visual="{iconPacks:FontAwesome Kind=EraserSolid}" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock 
                                Grid.Column="1"
                                Text="{x:Static localization:Strings.EraseLocalPortHistory}"
                                Style="{StaticResource ButtonWithImageTextBlock}" />
                        </Grid>
                    </Button.Content>
                </Button>
            <Button 
                Margin="0,0,10,0"
                Command="{Binding Path=ClearRemotePortHistoryCommand}"
                Style="{StaticResource ImageWithTextButton}"
                IsEnabled="{Binding RemotePortsHaveItems, UpdateSourceTrigger=Explicit}">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Style="{StaticResource ButtonWithImageRectangle}">
                            <Rectangle.OpacityMask>
                                <VisualBrush Stretch="Uniform" Visual="{iconPacks:FontAwesome Kind=EraserSolid}" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock 
                            Grid.Column="1"
                            Text="{x:Static localization:Strings.EraseRemotePortHistory}"
                            Style="{StaticResource ButtonWithImageTextBlock}" />
                    </Grid>
                </Button.Content>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
